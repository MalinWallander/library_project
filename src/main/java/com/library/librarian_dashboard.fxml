<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.library.view.librarian.LibrarianDashboardController"
      prefWidth="500"
      prefHeight="350"
      spacing="10"
      style="-fx-padding: 20;">

    <Label text="Librarian dashboard" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    <Button text="Create Borrower" onAction="#handleCreateUser" />
    <Button text="Create Employee" onAction="#handleCreateEmployee" />
    <Button text="Add Item" onAction="#handleAddItem" />
    <Button text="Log out" onAction="#handleLogout" />

</VBox>
