<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.library.view.shared.FirstPageController"
            prefWidth="1000" prefHeight="650"
            styleClass="root-pane">

    <stylesheets>
        <String fx:value="@/styles/first_page.css"/>
    </stylesheets>

    <!-- ── Top navigation bar ── -->
    <top>
        <HBox styleClass="nav-bar" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="📖" styleClass="nav-logo-icon"/>
                <Label text="City Library" styleClass="nav-logo-text"/>
            </HBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Login button -->
            <Button fx:id="loginButton"
                    text="Login"
                    styleClass="nav-login-btn"
                    onAction="#handleLoginButton"/>
        </HBox>
    </top>

    <!-- ── Main content ── -->
    <center>
        <VBox alignment="CENTER" spacing="48" styleClass="content-area">
            <padding><Insets top="60" right="40" bottom="60" left="40"/></padding>

            <!-- Hero text -->
            <VBox alignment="CENTER" spacing="12">
                <Label text="Welcome to City Library" styleClass="hero-title"/>
                <Label text="Discover books, DVDs, and magazines from our extensive collection"
                       styleClass="hero-subtitle"/>
            </VBox>

            <!-- Feature cards -->
            <HBox alignment="CENTER" spacing="24">

                <!-- Search Catalog card (active) -->
                <VBox fx:id="searchCard"
                      styleClass="card, card-active"
                      alignment="CENTER"
                      spacing="16"
                      prefWidth="220" prefHeight="180"
                      onMouseClicked="#handleSearchCard">
                    <padding><Insets top="32" right="24" bottom="32" left="24"/></padding>

                    <StackPane styleClass="card-icon-circle, card-icon-circle-active">
                        <Label text="🔍" styleClass="card-icon"/>
                    </StackPane>

                    <VBox alignment="CENTER" spacing="6">
                        <Label text="Search Catalog" styleClass="card-title"/>
                        <Label text="Browse our collection of titles"
                               styleClass="card-subtitle"
                               wrapText="true" textAlignment="CENTER"/>
                    </VBox>
                </VBox>

                <!-- My Loans card (locked) -->
                <VBox fx:id="loansCard"
                      styleClass="card, card-locked"
                      alignment="CENTER"
                      spacing="16"
                      prefWidth="220" prefHeight="180"
                      onMouseClicked="#handleLoansCard">
                    <padding><Insets top="32" right="24" bottom="32" left="24"/></padding>

                    <StackPane styleClass="card-icon-circle, card-icon-circle-locked">
                        <Label text="📖" styleClass="card-icon-locked"/>
                        <!-- Lock badge -->
                        <Label text="🔒" styleClass="card-lock-badge"/>
                    </StackPane>

                    <VBox alignment="CENTER" spacing="6">
                        <Label text="My Loans" styleClass="card-title-locked"/>
                        <Label text="Login required" styleClass="card-subtitle-locked"/>
                    </VBox>
                </VBox>

                <!-- My Reservations card (locked) -->
                <VBox fx:id="reservationsCard"
                      styleClass="card, card-locked"
                      alignment="CENTER"
                      spacing="16"
                      prefWidth="220" prefHeight="180"
                      onMouseClicked="#handleReservationsCard">
                    <padding><Insets top="32" right="24" bottom="32" left="24"/></padding>

                    <StackPane styleClass="card-icon-circle, card-icon-circle-locked">
                        <Label text="📅" styleClass="card-icon-locked"/>
                        <Label text="🔒" styleClass="card-lock-badge"/>
                    </StackPane>

                    <VBox alignment="CENTER" spacing="6">
                        <Label text="My Reservations" styleClass="card-title-locked"/>
                        <Label text="Login required" styleClass="card-subtitle-locked"/>
                    </VBox>
                </VBox>

            </HBox>
        </VBox>
    </center>

</BorderPane>
