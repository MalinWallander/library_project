<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" alignment="CENTER"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.library.view.user.ReservationController"
      prefWidth="350" prefHeight="300"
      styleClass="root-pane"
      stylesheets="@main.css"
      style="-fx-padding: 25;">

    <Label text="Confirm reservation" styleClass="page-title" />

    <VBox spacing="12" styleClass="info-container">
        <VBox>
            <Label text="TITLE" styleClass="label-hint" />
            <Label fx:id="titleLabel" styleClass="card-title" />
        </VBox>
        
        <VBox>
            <Label text="CREATOR" styleClass="label-hint" />
            <Label fx:id="creatorLabel" styleClass="card-title" />
        </VBox>
    </VBox>

    <HBox spacing="15" alignment="CENTER">
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary" />
        <Button text="Confirm" onAction="#handleConfirmReservation" styleClass="btn-primary" />
    </HBox>

</VBox>