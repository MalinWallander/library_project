<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.library.view.user.UserPageController"
            prefWidth="1000" prefHeight="650"
            styleClass="root-pane">

    <!-- Nav bar -->
    <top>
        <HBox styleClass="nav-bar" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="📖" styleClass="nav-logo-icon"/>
                <Label text="City Library" styleClass="nav-logo-text"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="16">
                <Label text="👤 Customer Portal" styleClass="nav-portal-label"/>
                <Button fx:id="logoutButton" text="⇥ Logout"
                        styleClass="nav-logout-btn" onAction="#handleLogout"/>
            </HBox>
        </HBox>
    </top>

    <!-- Main content -->
    <center>
        <VBox styleClass="content-area">
            <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

            <!-- Heading -->
            <VBox spacing="6">
                <Label fx:id="welcomeLabel" text="Welcome Back!" styleClass="page-title"/>
                <Label text="Manage your loans and reservations" styleClass="page-subtitle"/>
            </VBox>

            <!-- Top cards row -->
            <HBox spacing="24">
                <VBox.margin><Insets top="32"/></VBox.margin>

                <!-- Search Catalog -->
                <VBox fx:id="searchCard" styleClass="staff-card" alignment="CENTER"
                      spacing="16" prefWidth="300" prefHeight="200"
                      onMouseClicked="#handleSearch">
                    <padding><Insets top="32" right="24" bottom="32" left="24"/></padding>
                    <StackPane styleClass="card-icon-circle">
                        <Label text="🔍" styleClass="card-icon"/>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="Search Catalog" styleClass="card-title"/>
                        <Label text="Browse our collection" styleClass="card-subtitle"/>
                    </VBox>
                </VBox>

                <!-- My Loans -->
                <VBox fx:id="loansCard" styleClass="staff-card" alignment="CENTER"
                      spacing="16" prefWidth="300" prefHeight="200"
                      onMouseClicked="#handleLoans">
                    <padding><Insets top="32" right="24" bottom="32" left="24"/></padding>
                    <StackPane styleClass="card-icon-circle">
                        <Label text="📖" styleClass="card-icon"/>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="My Loans" styleClass="card-title"/>
                        <Label text="View your current loans" styleClass="card-subtitle"/>
                    </VBox>
                    <!-- <HBox alignment="CENTER">
                        <Label fx:id="activeLoansLabel" text="" styleClass="badge"/>
                    </HBox> -->
                </VBox>

                <!-- My Reservations -->
                <VBox fx:id="reservationsCard" styleClass="staff-card" alignment="CENTER"
                      spacing="16" prefWidth="300" prefHeight="200"
                      onMouseClicked="#handleReservations">
                    <padding><Insets top="32" right="24" bottom="32" left="24"/></padding>
                    <StackPane styleClass="card-icon-circle">
                        <Label text="📅" styleClass="card-icon"/>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="My Reservations" styleClass="card-title"/>
                        <Label text="Manage reservations" styleClass="card-subtitle"/>
                    </VBox>
                    <!-- <HBox alignment="CENTER">
                        <Label fx:id="pendingReservationsLabel" text="" styleClass="badge"/>
                    </HBox> -->
                </VBox>
            </HBox>

            <!-- Bottom panels row -->
            <HBox spacing="24">
                <VBox.margin><Insets top="24"/></VBox.margin>

                <!-- Recent Loans panel -->
                <!-- <VBox styleClass="staff-card" spacing="12"
                      prefWidth="440" prefHeight="260">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="Recent Loans" styleClass="card-title"/>
                    <VBox fx:id="recentLoansContainer" spacing="8"/>
                </VBox> -->

                <!-- Pending Reservations panel -->
                <!-- <VBox styleClass="staff-card" spacing="12"
                      prefWidth="440" prefHeight="260">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="Pending Reservations" styleClass="card-title"/>
                    <VBox fx:id="pendingReservationsContainer" spacing="8"/>
                </VBox> -->

            </HBox>

            
        </VBox>
    </center>

</BorderPane>