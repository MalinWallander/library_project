<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.library.view.shared.SearchController"
      prefHeight="600.0"
      prefWidth="900.0"
      styleClass="root-pane">

    <HBox spacing="15"
           alignment="CENTER"
           styleClass="search-bar">

        <TextField fx:id="searchField"
                   promptText="Search by title..."
                   prefWidth="200.0"/>

        <TextField fx:id="creatorField"
                   promptText="Search by author / director..."
                   prefWidth="220.0"/>

        <ComboBox fx:id="typeDropdown"
                  promptText="Select type..."
                  prefWidth="160.0"/>

        <Button text="Search"
                onAction="#handleSearch"
               styleClass="nav-login-btn"/>
    </HBox>

    <VBox alignment="CENTER"
          VBox.vgrow="ALWAYS"
          style="-fx-padding: 0 20 20 20;">

        <TableView fx:id="resultsTable"
                   prefWidth="820"
                   prefHeight="500">

            <columns>

                <TableColumn fx:id="titleColumn"
                             text="Title"
                             prefWidth="250.0"/>

                <TableColumn fx:id="creatorColumn"
                             text="Author / Director"
                             prefWidth="250.0"/>

                <TableColumn fx:id="statusColumn"
                             text="Status"
                             prefWidth="180.0"/>

                <TableColumn fx:id="reserveColumn"
                             text="Reserve"
                             prefWidth="120.0"/>

            </columns>

        </TableView>

    </VBox>

</VBox>