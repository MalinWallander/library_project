<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox spacing="10" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="view.shared.SearchController" prefHeight="600.0" prefWidth="800.0">
    
    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="searchField" promptText="Sök på titel eller författare..." prefWidth="300.0"/>
        <Button text="Sök" onAction="#handleSearch"/>
    </HBox>

    <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Titel" prefWidth="300.0">
                <cellValueFactory>
                    <PropertyValueFactory property="itemTitle" />
                </cellValueFactory>
            </TableColumn>

            <TableColumn text="Typ" prefWidth="150.0">
                <cellValueFactory>
                    <PropertyValueFactory property="itemType" />
                </cellValueFactory>
            </TableColumn>

            <TableColumn text="Kategori" prefWidth="150.0">
                <cellValueFactory>
                    <PropertyValueFactory property="categoryId" />
                </cellValueFactory>
            </TableColumn>

            <TableColumn text="Status" prefWidth="150.0">
                <cellValueFactory>
                    <PropertyValueFactory property="status" />
                </cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>
</VBox>
