<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.library.view.shared.SearchController"
      prefHeight="600"
      prefWidth="900"
      styleClass="root-pane"
      stylesheets="@styles/main.css"> <!-- VIKTIGT: Denna rad laddar in din design -->

    <!-- Sökfältet med padding för att det inte ska ligga mot kanten -->
    <HBox spacing="15"
      alignment="CENTER"
      styleClass="search-bar"
      style="-fx-padding: 30 0 10 0;">

    <TextField fx:id="searchField"
               promptText="Search by title..."
               prefWidth="200.0"
               styleClass="text-field"
               onKeyReleased="#handleSearch"/>

    <TextField fx:id="creatorField"
               promptText="Search by author / director..."
               prefWidth="220.0"
               onKeyReleased="#handleSearch"/>

    <ComboBox fx:id="typeDropdown"
              promptText="Select type..."
              prefWidth="160.0"
              onAction="#handleSearch"/>

</HBox>

    <VBox alignment="CENTER"
          VBox.vgrow="ALWAYS"
          style="-fx-padding: 0 40 40 40;">

        <!-- Använd staff-card klassen för att få den vita bakgrunden med skugga -->
        <TableView fx:id="resultsTable"
                   prefWidth="820"
                   VBox.vgrow="ALWAYS"
                   styleClass="staff-card">

            <columns>
                <TableColumn fx:id="titleColumn"
                             text="Title"
                             prefWidth="250.0"/>

                <TableColumn fx:id="creatorColumn"
                             text="Author / Director"
                             prefWidth="250.0"/>

                <TableColumn fx:id="statusColumn"
                             text="Status"
                             prefWidth="180.0"/>

                <TableColumn fx:id="reserveColumn"
                             text="Reserve"
                             prefWidth="120.0"/>
            </columns>
        </TableView>

    </VBox>

</VBox>