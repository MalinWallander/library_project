<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.library.view.shared.OverdueLoansController">

    <top>
        <VBox alignment="CENTER" spacing="10"
              style="-fx-padding: 25;">
            
            <Label text="Försenade lån"
                   style="-fx-font-size: 28px;
                          -fx-font-weight: bold;" />
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER"
              style="-fx-padding: 20;">

            <TableView fx:id="loanTable"
                       prefWidth="700"
                       prefHeight="500">

                <columns>

                    <TableColumn fx:id="copyIdColumn"
                                 text="Copy ID"
                                 prefWidth="220"/>

                    <TableColumn fx:id="userIdColumn"
                                 text="User ID"
                                 prefWidth="220"/>

                    <TableColumn fx:id="dueDateColumn"
                                 text="Due date"
                                 prefWidth="220"/>

                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>