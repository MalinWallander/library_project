<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.library.view.shared.OverdueLoansController"
            styleClass="page-background">

    <top>
        <VBox alignment="CENTER"
              spacing="10"
              style="-fx-padding: 30 0 10 0;">

            <Label text="Overdue Loans"
                   styleClass="page-title"/>

        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER"
              VBox.vgrow="ALWAYS"
              styleClass="table-wrapper">

            <TableView fx:id="loanTable"
                       prefWidth="720"
                       prefHeight="500">

                <columns>

                    <TableColumn fx:id="copyIdColumn"
                                 text="Copy ID"
                                 prefWidth="220"/>

                    <TableColumn fx:id="userIdColumn"
                                 text="User ID"
                                 prefWidth="220"/>

                    <TableColumn fx:id="dueDateColumn"
                                 text="Due Date"
                                 prefWidth="220"/>

                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>