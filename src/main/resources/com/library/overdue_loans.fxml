<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.library.view.shared.OverdueLoansController"
      styleClass="popup-root"
      spacing="16" prefWidth="700" prefHeight="500">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Overdue Loans" styleClass="page-title"/>

    <TableView fx:id="loanTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="itemTitleColumn" text="Item" prefWidth="220"/>
            <TableColumn fx:id="memberNameColumn" text="Member" prefWidth="180"/>
            <TableColumn fx:id="dueDateColumn" text="Due Date" prefWidth="120"/>
            <TableColumn fx:id="daysOverdueColumn" text="Days Overdue" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>