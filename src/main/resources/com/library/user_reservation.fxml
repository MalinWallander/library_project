<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.library.view.user.UserReservationsController"
      prefWidth="900" prefHeight="650"
      styleClass="root-pane"
      stylesheets="@styles/main.css">
    
    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <Label text="My reservations" styleClass="page-title" />

    <!-- TableView använder staff-card klassen för vit bakgrund och skugga -->
    <TableView fx:id="reservationsTable" VBox.vgrow="ALWAYS" styleClass="staff-card">
        <columns>
            <TableColumn fx:id="titleColumn" text="Titel" prefWidth="250" />
            <TableColumn fx:id="creatorColumn" text="Writer / Director" prefWidth="200" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="150" />
            <TableColumn fx:id="cancelColumn" text="Handle" prefWidth="150" />
        </columns>
    </TableView>

    <Button text="Back to menu" 
            onAction="#handleBackToDashboard" 
            styleClass="btn-secondary" />
</VBox>